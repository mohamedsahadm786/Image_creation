# ─── REQUIRED ───────────────────────────────────────────────────────────
# Anthropic API key — for Opus 4.7 prompt building and Sonnet checking
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# fal.ai API key — for PuLID Step 1 and Nano Banana 2 Edit Step 2
# Note: variable name MUST be FAL_KEY, not FAL_API_KEY (fal-client convention)
# Get from: https://fal.ai/dashboard/keys
FAL_KEY=...

# ─── OPTIONAL ───────────────────────────────────────────────────────────
# These are not used by Plan A/B but kept for forward compatibility:

# Apify token — only needed if reintroducing TikTok scraping later (not used in v2)
# APIFY_API_TOKEN=apify_api_...

# Google Gemini API key — only if calling Gemini directly bypassing fal (not used in v2)
# GEMINI_API_KEY=...